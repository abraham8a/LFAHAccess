<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Premium QR Validator</title>
    <script src="https://unpkg.com/html5-qrcode"></script>
    <style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap');

:root {
    --bg-color: #0d1117;
    --card-bg: rgba(22, 27, 34, 0.7);
    --border-color: rgba(255, 255, 255, 0.1);
    --text-color: #c9d1d9;
    --text-muted: #8b949e;
    --primary: #2ea043;
    --primary-hover: #238636;
    --danger: #da3633;
    --valid-green: #238636;
    --invalid-red: #da3633;
}

body {
    margin: 0;
    background: var(--bg-color);
    color: var(--text-color);
    font-family: 'Inter', sans-serif;
    text-align: center;
    overflow: hidden;
    touch-action: manipulation;
    height: 100dvh;
    display: flex;
    flex-direction: column;
}

h1, h2 {
    color: #ffffff;
    margin-top: 0;
    letter-spacing: -0.5px;
}

/* Glassmorphism Card */
.glass-card {
    background: var(--card-bg);
    backdrop-filter: blur(10px);
    border: 1px solid var(--border-color);
    border-radius: 20px;
    padding: 2rem;
    max-width: 400px;
    width: 90%;
    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.5);
}

.panel {
    display: flex;
    flex: 1;
    height: 100%;
    justify-content: center;
    align-items: center;
}

.glass-card p {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: 2rem;
}

/* Inputs */
.input-group {
    text-align: left;
    margin-bottom: 1.5rem;
}

.input-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: #ffffff;
}

.input-group input {
    width: 100%;
    box-sizing: border-box;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 12px 15px;
    color: #ffffff;
    font-size: 1rem;
    outline: none;
    transition: all 0.2s;
}

.input-group input:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(46, 160, 67, 0.2);
}

/* Buttons */
button {
    cursor: pointer;
    border-radius: 10px;
    border: none;
    font-family: inherit;
    font-weight: 600;
    transition: all 0.2s;
}

.btn-primary {
    padding: 15px 30px;
    font-size: 1.2rem;
    background: var(--primary);
    color: white;
    width: 100%;
    margin-top: 10px;
    box-shadow: 0 4px 14px rgba(46, 160, 67, 0.4);
}

.btn-primary:hover {
    background: var(--primary-hover);
    transform: translateY(-2px);
}

.btn-secondary {
    padding: 8px 16px;
    font-size: 0.8rem;
    background: rgba(255,255,255,0.1);
    color: white;
}

.btn-secondary:hover {
    background: rgba(255,255,255,0.2);
}

/* Scanner UI */
#mainUI {
    display: none; /* Toggled to flex */
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    height: 100dvh;
    padding: 3dvh 0;
    box-sizing: border-box;
}

.header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 5%;
    width: 90%;
    max-width: 500px;
    flex-shrink: 0;
}

.header h2 { margin: 0; font-size: 1.5rem; }

#reader-container {
    width: 90%;
    max-width: 500px;
    flex: 1; /* Stretches dynamically */
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 15px 0;
    border-radius: 20px;
    padding: 5px;
    background: linear-gradient(145deg, rgba(255,255,255,0.05), rgba(0,0,0,0.5));
    border: 1px solid var(--border-color);
    overflow: hidden;
}

#reader {
    width: 100%;
    border-radius: 15px;
    overflow: hidden;
    position: relative;
}

#reader video {
    object-fit: cover !important; /* Maximizes frame within the container natively */
}

/* Stats */
#stats {
    flex-shrink: 0;
    font-size: 1rem;
    letter-spacing: 1px;
    color: var(--text-muted);
    text-transform: uppercase;
    font-weight: 600;
}

#count {
    font-size: 4rem;
    font-weight: 800;
    color: var(--primary);
    display: block;
    margin-top: 2px;
    text-shadow: 0 0 20px rgba(46, 160, 67, 0.4);
}

/* Full Screen Overlay */
#overlay {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    display: none;
    justify-content: center;
    align-items: center;
    z-index: 9999;
    font-size: 10vw;
    font-weight: 900;
    text-transform: uppercase;
}

.valid-bg { 
    background-color: var(--valid-green); 
    color: white;
    animation: valid-pop 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.flash-red { 
    color: white;
    background: var(--invalid-red);
    animation: rapid-blink 0.15s infinite; 
}

@keyframes valid-pop {
    0% { transform: scale(0.9); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
}

@keyframes rapid-blink {
    0% { background: var(--invalid-red); }
    50% { background: #000000; }
    100% { background: var(--invalid-red); }
}

/* Responsiveness for Rotating Device / Landscape */
@media (orientation: landscape) and (max-height: 600px) {
    #mainUI {
        flex-direction: row;
        padding: 5% 5%;
    }
    .header {
        flex-direction: column;
        width: 30%;
        max-width: none;
        align-items: flex-start;
        justify-content: center;
        gap: 15px;
    }
    #reader-container {
        width: 40%;
        margin: 0;
        height: 100%;
    }
    #stats {
        width: 30%;
        text-align: right;
    }
    #count {
        font-size: 3rem;
    }
}
    </style>
</head>
<body>

    <div id="setup" class="panel">
        <div class="glass-card">
            <h1>Asamblea Regional 2026</h1>
            <p>Scanner System Ready</p>
            <button id="startBtn" class="btn-primary">Tap to Start Scanner</button>
        </div>
    </div>

    <div id="mainUI" style="display: none;">
        <div class="header">
            <h2>Asamblea Regional 2026</h2>
            <button id="resetScanBtn" class="btn-secondary">Reset</button>
        </div>
        
        <div id="reader-container">
            <div id="reader"></div>
        </div>

        <div id="stats">
            Valid Admissions
            <span id="count">0</span>
        </div>
    </div>

    <div id="overlay">
        <span id="overlayText">VALID</span>
    </div>

    <script>
// CONFIGURATION
const APP_CONFIG = {
    // If set, ONLY this exact text will be considered VALID.
    // Leave empty ("") to use default date-matching logic.
    VALID_PARAMETER: "AsambleaRegional2026", 

    // If set, this exact text will explicitly be INVALID.
    INVALID_PARAMETER: "",

    // PIN code required to reset the admission counter
    RESET_PIN: "1234",
    
    // Globally unique namespace for cross-device sync
    GLOBAL_NAMESPACE: "lfah-access-global-event-2026"
};

// APPLICATION LOGIC
let validScans = 0; // Will be polled globally
let currentSessionId = 0;
let isProcessing = false;
let audioCtx;

const setupDiv = document.getElementById('setup');
const mainUIDiv = document.getElementById('mainUI');
const overlay = document.getElementById('overlay');
const countDisplay = document.getElementById('count');
const overlayText = document.getElementById('overlayText');

const config = typeof APP_CONFIG !== 'undefined' ? APP_CONFIG : {
    VALID_PARAMETER: "", INVALID_PARAMETER: "", RESET_PIN: "1234", GLOBAL_NAMESPACE: "lfah-access-global-event-2026"
};

const COUNT_API_BASE = `https://api.counterapi.dev/v1/${config.GLOBAL_NAMESPACE}`;

// Polling function to keep devices in sync
async function fetchGlobalState() {
    try {
        // 1. Check current session ID
        let sessionRes = await fetch(`${COUNT_API_BASE}/session_id`, { cache: "no-store" });
        if (!sessionRes.ok) throw new Error("No session");
        let sessionData = await sessionRes.json();
        currentSessionId = sessionData.count || 0;
    } catch(e) {
        currentSessionId = 0;
    }

    try {
        // 2. Fetch scans for this active session
        let scansRes = await fetch(`${COUNT_API_BASE}/scans_session_${currentSessionId}`, { cache: "no-store" });
        if (scansRes.ok) {
            let scansData = await scansRes.json();
            validScans = scansData.count || 0;
        } else {
            validScans = 0;
        }
    } catch(e) {
        validScans = 0;
    }

    // Update UI
    countDisplay.innerText = validScans;
}

// Automatically sync every 3 seconds
setInterval(fetchGlobalState, 3000);

document.getElementById('startBtn').addEventListener('click', async function() {
    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    setupDiv.style.display = 'none';
    mainUIDiv.style.display = 'flex'; // Use flex for the new layout overrides
    
    // Fetch initial state immediately
    countDisplay.innerText = "...";
    await fetchGlobalState();
    
    startScanner();
});

document.getElementById('resetScanBtn').addEventListener('click', async function() {
    const pin = prompt('Enter PIN to reset global counter:');
    if (pin === config.RESET_PIN) {
        try {
            validScans = 0;
            countDisplay.innerText = "...";
            // Increment the session ID globally to "reset" the count to a fresh 0 state
            await fetch(`${COUNT_API_BASE}/session_id/up`, { cache: "no-store" });
            await fetchGlobalState();
            alert('Global counter reset successfully active across all devices!');
        } catch(e) {
            alert('Error connecting to sync server. Try again.');
        }
    } else if (pin !== null) {
        alert('Incorrect PIN.');
    }
});

function playSound(freq, waveType) {
    if (!audioCtx) return;
    const osc = audioCtx.createOscillator();
    const gain = audioCtx.createGain();
    osc.type = waveType || 'sine';
    osc.frequency.setValueAtTime(freq, audioCtx.currentTime);
    osc.connect(gain);
    gain.connect(audioCtx.destination);
    osc.start();
    // Taper off sound quickly
    gain.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + 0.5);
    osc.stop(audioCtx.currentTime + 0.5);
}

function checkDateLogic(decodedText) {
    const today = new Date().toISOString().split('T')[0];
    const dates = decodedText.trim().split('|');

    if (dates.length === 2) {
        const start = dates[0];
        const end = dates[1];
        if (today >= start && today <= end) {
            return true;
        }
    } else if (dates.length === 1) {
        if (decodedText.trim() === today) {
            return true;
        }
    }
    return false;
}

function onScanSuccess(decodedText) {
    if (isProcessing) return;
    isProcessing = true;

    let isValid = false;
    let explicitStatus = false;

    // Check custom valid parameter
    if (config.VALID_PARAMETER !== "") {
        if (decodedText.trim() === config.VALID_PARAMETER) {
            isValid = true;
            explicitStatus = true;
        }
    }

    // Check custom invalid parameter
    if (!isValid && config.INVALID_PARAMETER !== "") {
        if (decodedText.trim() === config.INVALID_PARAMETER) {
            isValid = false;
            explicitStatus = true;
        }
    }

    // Fallback to Date Logic if no parameter rules matched or were supplied
    if (!explicitStatus) {
        isValid = checkDateLogic(decodedText);
    }

    triggerUI(isValid);
}

async function triggerUI(isValid) {
    overlay.style.display = 'flex';

    if (isValid) {
        // Optimistic UI Update locally for instant feedback
        validScans++;
        countDisplay.innerText = validScans;
        overlay.className = 'valid-bg';
        overlayText.innerText = 'VALID';
        playSound(1200, 'sine'); // High pitch beep
        
        // Push globally behind the scenes
        try {
            await fetch(`${COUNT_API_BASE}/scans_session_${currentSessionId}/up`, { cache: "no-store" });
        } catch(e) { console.error('Failed to sync scan', e); }
    } else {
        overlay.className = 'flash-red';
        overlayText.innerText = 'INVALID';
        playSound(120, 'square'); // Low pitch buzz
    }

    // Lock scanner for 2.5 seconds to prevent double scans
    setTimeout(() => {
        overlay.style.display = 'none';
        overlay.className = '';
        isProcessing = false;
    }, 2500);
}

function startScanner() {
    const html5QrCode = new Html5Qrcode("reader");
    
    // Dynamic QRBox size depending on viewport
    const renderConfig = { 
        fps: 15, 
        qrbox: function(viewfinderWidth, viewfinderHeight) {
            let minEdgeSizeThreshold = Math.min(viewfinderWidth, viewfinderHeight);
            // 70% of the smallest viewport dimension
            let qrboxSize = Math.floor(minEdgeSizeThreshold * 0.7);
            return {
                width: qrboxSize,
                height: qrboxSize
            };
        }
    };

    html5QrCode.start(
        { facingMode: "environment" }, 
        renderConfig, 
        onScanSuccess
    ).catch(err => {
        alert("Camera Error: " + err);
    });
}
    </script>
</body>
</html>
